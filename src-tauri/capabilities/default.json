{
  "identifier": "default",
  "description": "Default capabilities for cluihud",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:app:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-show",
    "core:window:allow-hide",
    "dialog:default"
  ]
}
