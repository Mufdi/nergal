/target
src-tauri/target/
node_modules/
*.swp
*.swo
*~
.DS_Store

# Build artifacts
dist/

# Local runtime / tooling state
.worktrees/
.playwright-cli/

# Claude Code local configuration (symlinks to external skills dir, per-session plans, local settings)
.claude/plans/
.claude/settings.local.json
.claude/skills/
.claude/commands/

# External agent tooling symlinks (not part of this repo)
.agent/
.opencode/

# External assets referenced only from docs outside this repo
logos-ide/
logos-agents/

# Claude Code scheduled-tasks runtime state
.claude/scheduled_tasks.lock

# Multi-session scratch docs
cross-session.md
cross-session-protocol.md

# Tauri auto-generated schemas (regenerated by tauri-build on every build).
# Source of truth: src-tauri/capabilities/.
src-tauri/gen/

# Updater signing — private keys, passphrases, certs. The PUBLIC key
# lives in src-tauri/tauri.conf.json (safe to commit); the PRIVATE key
# is generated locally by `pnpm tauri signer generate` and goes to
# ~/.tauri/, never the repo.
*.key
*.pem
*.p12
*.pfx
.tauri/
TAURI_SIGNING_*
